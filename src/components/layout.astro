---
import '../styles/global.css';
const { title, description = "Pretty Little Bingo - The ultimate online bingo and casino experience" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-gradient-to-br from-bingo-purple via-bingo-pink to-bingo-gold min-h-screen">
    <nav class="bg-casino-black/90 backdrop-blur-sm text-white p-4 shadow-lg sticky top-0 z-50">
      <div class="container mx-auto flex justify-between items-center">
        <div class="flex items-center space-x-2">
          <span class="text-3xl">🎰</span>
          <h1 class="text-2xl font-bold font-fancy text-bingo-gold">Pretty Little Bingo</h1>
        </div>
        <div class="hidden md:flex space-x-6">
          <a href="/" class="hover:text-bingo-pink transition-colors duration-200">Home</a>
          <a href="/bingo" class="hover:text-bingo-pink transition-colors duration-200">Bingo</a>
          <a href="/casino" class="hover:text-bingo-pink transition-colors duration-200">Casino</a>
          <a href="/slots" class="hover:text-bingo-pink transition-colors duration-200">Slots</a>
          <a href="/roulette" class="hover:text-bingo-pink transition-colors duration-200">Roulette</a>
        </div>
        <div class="flex items-center space-x-4">
          <span class="text-bingo-gold font-bold">💰 $1,000</span>
          <button class="bg-bingo-pink hover:bg-bingo-purple px-4 py-2 rounded-lg transition-colors duration-200">
            Play Now
          </button>
        </div>
      </div>
    </nav>

    <main class="container mx-auto px-4 py-8">
      <slot />
    </main>

    <footer class="bg-casino-black text-white py-8 mt-16">
      <div class="container mx-auto px-4 text-center">
        <div class="flex justify-center items-center space-x-2 mb-4">
          <span class="text-2xl">🎰</span>
          <h2 class="text-xl font-bold font-fancy text-bingo-gold">Pretty Little Bingo</h2>
        </div>
        <p class="text-gray-300 mb-4">The ultimate online bingo and casino experience</p>
        <p class="text-sm text-gray-400">© 2024 Pretty Little Bingo. All rights reserved. Play responsibly.</p>
      </div>
    </footer>

    <script>
      // Add some sparkle effects
      function createSparkle() {
        const sparkle = document.createElement('div');
        sparkle.className = 'fixed pointer-events-none z-10';
        sparkle.innerHTML = '✨';
        sparkle.style.left = Math.random() * window.innerWidth + 'px';
        sparkle.style.top = Math.random() * window.innerHeight + 'px';
        sparkle.style.fontSize = Math.random() * 20 + 10 + 'px';
        sparkle.style.opacity = Math.random() * 0.5 + 0.5;
        document.body.appendChild(sparkle);
        
        setTimeout(() => {
          sparkle.remove();
        }, 3000);
      }
      
      setInterval(createSparkle, 2000);
    </script>
  </body>
</html>
