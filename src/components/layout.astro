---
const { title, description, home = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Preload fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
  
  <!-- Favicons -->
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest" />

  <meta name="msapplication-TileColor" content="#3b82f6" />
  <meta name="theme-color" content="#ffffff" />
  
  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>

  <!-- Global styles -->
  <style is:global>
    @import 'tailwindcss/base';
    @import 'tailwindcss/components';
    @import 'tailwindcss/utilities';

    * {
      box-sizing: border-box;
    }

    html {
      font-family: 'Inter', system-ui, sans-serif;
    }

    body {
      @apply bg-white dark:bg-dark-900 text-gray-900 dark:text-gray-100 transition-colors duration-300;
      line-height: 1.6;
      margin: 0;
      padding: 0;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
    }

    ::-webkit-scrollbar-track {
      @apply bg-gray-100 dark:bg-dark-800;
    }

    ::-webkit-scrollbar-thumb {
      @apply bg-gray-300 dark:bg-dark-600 rounded-lg;
    }

    ::-webkit-scrollbar-thumb:hover {
      @apply bg-gray-400 dark:bg-dark-500;
    }

    /* Smooth animations */
    * {
      transition: color 0.3s ease, background-color 0.3s ease, border-color 0.3s ease;
    }
  </style>

  <!-- Dark mode script -->
  <script is:inline>
    // Dark mode toggle
    function initTheme() {
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark')
        localStorage.theme = 'dark'
      } else {
        document.documentElement.classList.remove('dark')
        localStorage.theme = 'light'
      }
    }
    initTheme();

    function toggleTheme() {
      if (document.documentElement.classList.contains('dark')) {
        document.documentElement.classList.remove('dark')
        localStorage.theme = 'light'
      } else {
        document.documentElement.classList.add('dark')
        localStorage.theme = 'dark'
      }
    }

    // Make toggleTheme available globally
    window.toggleTheme = toggleTheme;
  </script>
</head>
<body class="min-h-screen">
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-dark-900/80 backdrop-blur-md border-b border-gray-200 dark:border-dark-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center space-x-4">
          <a href="/" class="flex items-center space-x-2 text-xl font-bold text-primary-600 dark:text-primary-400">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
              <path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0L19.2 12l-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/>
            </svg>
            <span>AI Coder</span>
          </a>
        </div>
        
        <div class="hidden md:flex items-center space-x-8">
          <a href="/editor" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 font-medium">Editor</a>
          <a href="/playground" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 font-medium">Playground</a>
          <a href="/ai-assistant" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 font-medium">AI Assistant</a>
          <a href="/learn" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 font-medium">Learn</a>
        </div>

        <div class="flex items-center space-x-4">
          <!-- Dark mode toggle -->
          <button 
            onclick="window.toggleTheme()" 
            class="p-2 rounded-lg bg-gray-100 dark:bg-dark-800 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-dark-700 transition-colors"
            aria-label="Toggle dark mode"
          >
            <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM18.894 6.166a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM21.75 12a.75.75 0 01-.75.75h-2.25a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.834 18.894a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 10-1.061 1.06l1.59 1.591zM12 18a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-2.25A.75.75 0 0112 18zM7.758 17.303a.75.75 0 00-1.061-1.06l-1.591 1.59a.75.75 0 001.06 1.061l1.591-1.59zM6 12a.75.75 0 01-.75.75H3a.75.75 0 010-1.5h2.25A.75.75 0 016 12zM6.697 7.757a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 00-1.061 1.06l1.59 1.591z"/>
            </svg>
            <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 24 24">
              <path d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/>
            </svg>
          </button>
          
          <a href="/get-started" class="bg-primary-600 hover:bg-primary-700 text-white px-4 py-2 rounded-lg font-medium transition-colors">
            Get Started
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Main content -->
  <main class="pt-16">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-gray-50 dark:bg-dark-800 border-t border-gray-200 dark:border-dark-700 mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="col-span-1 md:col-span-2">
          <div class="flex items-center space-x-2 text-xl font-bold text-primary-600 dark:text-primary-400 mb-4">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
              <path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0L19.2 12l-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/>
            </svg>
            <span>AI Coder</span>
          </div>
          <p class="text-gray-600 dark:text-gray-300 mb-4 max-w-md">
            The ultimate AI-powered coding platform. Write, test, and deploy code with the help of advanced AI assistance.
          </p>
        </div>
        
        <div>
          <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-4">Product</h3>
          <ul class="space-y-2">
            <li><a href="/editor" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Code Editor</a></li>
            <li><a href="/playground" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Playground</a></li>
            <li><a href="/ai-assistant" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">AI Assistant</a></li>
            <li><a href="/templates" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Templates</a></li>
          </ul>
        </div>
        
        <div>
          <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-4">Resources</h3>
          <ul class="space-y-2">
            <li><a href="/docs" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Documentation</a></li>
            <li><a href="/tutorials" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Tutorials</a></li>
            <li><a href="/blog" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Blog</a></li>
            <li><a href="/community" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Community</a></li>
          </ul>
        </div>
      </div>
      
      <div class="border-t border-gray-200 dark:border-dark-700 mt-8 pt-8">
        <p class="text-center text-gray-500 dark:text-gray-400 text-sm">
          © 2024 AI Coder. Built with ❤️ for developers worldwide.
        </p>
      </div>
    </div>
  </footer>
</body>
</html>
