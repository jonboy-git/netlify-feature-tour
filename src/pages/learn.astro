  <!-- Learning Interactive Scripts -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Learning path interactions
      const learningPaths = document.querySelectorAll('.learning-path');
      learningPaths.forEach(path => {
        path.addEventListener('click', () => {
          const pathType = path.dataset.path;
          showPathModal(pathType);
        });
      });

      // Challenge card interactions
      const challengeCards = document.querySelectorAll('.challenge-card');
      challengeCards.forEach(card => {
        card.addEventListener('click', () => {
          const difficulty = card.dataset.difficulty;
          window.location.href = '/playground?challenge=' + difficulty;
        });
      });

      function showPathModal(pathType) {
        const pathInfo = {
          javascript: {
            title: 'JavaScript Fundamentals',
            description: 'Master the building blocks of modern web development',
            lessons: [
              'Variables and Data Types',
              'Functions and Scope',
              'Objects and Arrays',
              'DOM Manipulation',
              'Event Handling',
              'Async Programming'
            ]
          },
          react: {
            title: 'React Development',
            description: 'Build modern, interactive user interfaces',
            lessons: [
              'JSX and Components',
              'Props and State',
              'Event Handling',
              'Lifecycle Methods',
              'Hooks (useState, useEffect)',
              'Context and State Management'
            ]
          },
          // Add more path info as needed
        };

        const info = pathInfo[pathType];
        if (info) {
          alert(`Starting ${info.title}!\n\n${info.description}\n\nFirst lesson: ${info.lessons[0]}`);
        }
      }

      // Smooth scrolling for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
          }
        });
      });
    });
  </script>
</Layout>