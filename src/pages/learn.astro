---
import Layout from '../components/layout.astro';
---

<Layout
  title="Learn - Interactive Coding Tutorials & Challenges"
  description="Master programming with interactive tutorials, coding challenges, and AI-guided learning paths."
>
  <div class="min-h-screen bg-gray-50 dark:bg-dark-900">
    <!-- Hero Section -->
    <div class="bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-600 text-white py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h1 class="text-4xl lg:text-5xl font-bold mb-6">
            Learn to Code with AI
          </h1>
          <p class="text-xl lg:text-2xl text-indigo-100 mb-8 max-w-3xl mx-auto">
            Interactive tutorials, coding challenges, and personalized learning paths powered by AI.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="#start-learning" class="bg-white text-indigo-600 hover:bg-gray-100 px-8 py-4 rounded-lg font-semibold text-lg transition-all duration-300 transform hover:scale-105">
              Start Learning
            </a>
            <a href="#challenges" class="border-2 border-white text-white hover:bg-white hover:text-indigo-600 px-8 py-4 rounded-lg font-semibold text-lg transition-all duration-300 transform hover:scale-105">
              Try Challenges
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Learning Paths -->
    <section id="start-learning" class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-4">
            Choose Your Learning Path
          </h2>
          <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
            Structured learning paths designed to take you from beginner to expert.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- JavaScript Path -->
          <div class="learning-path bg-white dark:bg-dark-800 rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow cursor-pointer" data-path="javascript">
            <div class="bg-gradient-to-r from-yellow-400 to-orange-500 p-6">
              <div class="flex items-center space-x-4 text-white">
                <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center">
                  <span class="text-2xl font-bold">JS</span>
                </div>
                <div>
                  <h3 class="text-xl font-bold">JavaScript Fundamentals</h3>
                  <p class="text-yellow-100">12 lessons • 6 hours</p>
                </div>
              </div>
            </div>
            <div class="p-6">
              <p class="text-gray-600 dark:text-gray-300 mb-4">
                Master JavaScript from basics to advanced concepts including ES6+, async programming, and DOM manipulation.
              </p>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-500 dark:text-gray-400">Beginner</span>
                <div class="w-full max-w-20 bg-gray-200 dark:bg-dark-600 rounded-full h-2 ml-4">
                  <div class="bg-yellow-500 h-2 rounded-full" style="width: 25%"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- React Path -->
          <div class="learning-path bg-white dark:bg-dark-800 rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow cursor-pointer" data-path="react">
            <div class="bg-gradient-to-r from-blue-400 to-cyan-500 p-6">
              <div class="flex items-center space-x-4 text-white">
                <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center">
                  <span class="text-2xl font-bold">⚛</span>
                </div>
                <div>
                  <h3 class="text-xl font-bold">React Development</h3>
                  <p class="text-blue-100">15 lessons • 8 hours</p>
                </div>
              </div>
            </div>
            <div class="p-6">
              <p class="text-gray-600 dark:text-gray-300 mb-4">
                Build modern web applications with React, hooks, context, and state management.
              </p>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-500 dark:text-gray-400">Intermediate</span>
                <div class="w-full max-w-20 bg-gray-200 dark:bg-dark-600 rounded-full h-2 ml-4">
                  <div class="bg-blue-500 h-2 rounded-full" style="width: 60%"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Python Path -->
          <div class="learning-path bg-white dark:bg-dark-800 rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow cursor-pointer" data-path="python">
            <div class="bg-gradient-to-r from-green-400 to-blue-500 p-6">
              <div class="flex items-center space-x-4 text-white">
                <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center">
                  <span class="text-2xl font-bold">🐍</span>
                </div>
                <div>
                  <h3 class="text-xl font-bold">Python Programming</h3>
                  <p class="text-green-100">18 lessons • 10 hours</p>
                </div>
              </div>
            </div>
            <div class="p-6">
              <p class="text-gray-600 dark:text-gray-300 mb-4">
                Learn Python from basics to advanced topics including data structures, OOP, and libraries.
              </p>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-500 dark:text-gray-400">Beginner</span>
                <div class="w-full max-w-20 bg-gray-200 dark:bg-dark-600 rounded-full h-2 ml-4">
                  <div class="bg-green-500 h-2 rounded-full" style="width: 40%"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Algorithms Path -->
          <div class="learning-path bg-white dark:bg-dark-800 rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow cursor-pointer" data-path="algorithms">
            <div class="bg-gradient-to-r from-purple-400 to-pink-500 p-6">
              <div class="flex items-center space-x-4 text-white">
                <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center">
                  <span class="text-2xl font-bold">🧮</span>
                </div>
                <div>
                  <h3 class="text-xl font-bold">Data Structures & Algorithms</h3>
                  <p class="text-purple-100">20 lessons • 12 hours</p>
                </div>
              </div>
            </div>
            <div class="p-6">
              <p class="text-gray-600 dark:text-gray-300 mb-4">
                Master fundamental algorithms and data structures for technical interviews and problem-solving.
              </p>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-500 dark:text-gray-400">Advanced</span>
                <div class="w-full max-w-20 bg-gray-200 dark:bg-dark-600 rounded-full h-2 ml-4">
                  <div class="bg-purple-500 h-2 rounded-full" style="width: 15%"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Web Development Path -->
          <div class="learning-path bg-white dark:bg-dark-800 rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow cursor-pointer" data-path="web">
            <div class="bg-gradient-to-r from-red-400 to-pink-500 p-6">
              <div class="flex items-center space-x-4 text-white">
                <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center">
                  <span class="text-2xl font-bold">🌐</span>
                </div>
                <div>
                  <h3 class="text-xl font-bold">Full-Stack Web Development</h3>
                  <p class="text-red-100">25 lessons • 15 hours</p>
                </div>
              </div>
            </div>
            <div class="p-6">
              <p class="text-gray-600 dark:text-gray-300 mb-4">
                Complete web development course covering frontend, backend, databases, and deployment.
              </p>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-500 dark:text-gray-400">Intermediate</span>
                <div class="w-full max-w-20 bg-gray-200 dark:bg-dark-600 rounded-full h-2 ml-4">
                  <div class="bg-red-500 h-2 rounded-full" style="width: 30%"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Machine Learning Path -->
          <div class="learning-path bg-white dark:bg-dark-800 rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow cursor-pointer" data-path="ml">
            <div class="bg-gradient-to-r from-indigo-400 to-purple-500 p-6">
              <div class="flex items-center space-x-4 text-white">
                <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center">
                  <span class="text-2xl font-bold">🤖</span>
                </div>
                <div>
                  <h3 class="text-xl font-bold">Machine Learning</h3>
                  <p class="text-indigo-100">22 lessons • 14 hours</p>
                </div>
              </div>
            </div>
            <div class="p-6">
              <p class="text-gray-600 dark:text-gray-300 mb-4">
                Introduction to machine learning, neural networks, and AI development with practical projects.
              </p>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-500 dark:text-gray-400">Advanced</span>
                <div class="w-full max-w-20 bg-gray-200 dark:bg-dark-600 rounded-full h-2 ml-4">
                  <div class="bg-indigo-500 h-2 rounded-full" style="width: 10%"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Interactive Tutorial Demo -->
    <section class="py-20 bg-white dark:bg-dark-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-4">
            Interactive Learning Experience
          </h2>
          <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
            Learn by doing with our interactive code editor and real-time feedback.
          </p>
        </div>

        <div class="bg-gray-50 dark:bg-dark-700 rounded-xl overflow-hidden shadow-lg">
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <!-- Tutorial Content -->
            <div class="p-8">
              <div class="flex items-center space-x-4 mb-6">
                <div class="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center">
                  <span class="text-white font-bold">1</span>
                </div>
                <div>
                  <h3 class="text-xl font-bold text-gray-900 dark:text-white">Variables in JavaScript</h3>
                  <p class="text-gray-600 dark:text-gray-300">Learn how to declare and use variables</p>
                </div>
              </div>

              <div class="prose dark:prose-invert max-w-none mb-6">
                <p>In JavaScript, you can create variables to store data. There are three ways to declare variables:</p>
                <ul>
                  <li><code>var</code> - function-scoped (older way)</li>
                  <li><code>let</code> - block-scoped (preferred for mutable variables)</li>
                  <li><code>const</code> - block-scoped (for constants)</li>
                </ul>
                <p><strong>Task:</strong> Try creating a variable with your name and log it to the console.</p>
              </div>

              <div class="space-y-4">
                <div class="flex items-center space-x-2">
                  <div class="w-4 h-4 bg-green-500 rounded-full"></div>
                  <span class="text-sm text-gray-600 dark:text-gray-300">Objective: Create a variable named 'name'</span>
                </div>
                <div class="flex items-center space-x-2">
                  <div class="w-4 h-4 bg-yellow-500 rounded-full"></div>
                  <span class="text-sm text-gray-600 dark:text-gray-300">Objective: Assign your name to the variable</span>
                </div>
                <div class="flex items-center space-x-2">
                  <div class="w-4 h-4 bg-gray-300 dark:bg-dark-600 rounded-full"></div>
                  <span class="text-sm text-gray-600 dark:text-gray-300">Objective: Log the variable to console</span>
                </div>
              </div>

              <div class="mt-8 flex space-x-4">
                <button class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg transition-colors">
                  Run Code
                </button>
                <button class="bg-gray-600 hover:bg-gray-700 text-white px-6 py-2 rounded-lg transition-colors">
                  Get Hint
                </button>
                <button class="bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded-lg transition-colors">
                  Next Lesson
                </button>
              </div>
            </div>

            <!-- Code Editor -->
            <div class="bg-gray-900 text-green-400 p-8 font-mono">
              <div class="mb-4">
                <div class="flex items-center space-x-2 text-xs">
                  <span class="text-gray-500">1</span>
                  <span class="text-blue-400">// Your code here</span>
                </div>
                <div class="flex items-center space-x-2 text-xs">
                  <span class="text-gray-500">2</span>
                  <span class="text-yellow-400">const</span>
                  <span class="text-white">name</span>
                  <span class="text-white">=</span>
                  <span class="text-green-400">"</span>
                  <span class="animate-pulse bg-green-400 text-gray-900 px-1">|</span>
                </div>
                <div class="flex items-center space-x-2 text-xs">
                  <span class="text-gray-500">3</span>
                  <span></span>
                </div>
              </div>

              <div class="border-t border-gray-700 pt-4">
                <div class="text-xs text-gray-400 mb-2">Console Output:</div>
                <div class="text-sm">
                  <span class="text-gray-500">></span>
                  <span class="ml-2 text-gray-400">Run your code to see output here</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Coding Challenges -->
    <section id="challenges" class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-4">
            Coding Challenges
          </h2>
          <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
            Test your skills with coding challenges ranging from beginner to advanced levels.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Easy Challenge -->
          <div class="challenge-card bg-white dark:bg-dark-800 rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow cursor-pointer" data-difficulty="easy">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center space-x-2">
                <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                <span class="text-sm font-medium text-green-600 dark:text-green-400">Easy</span>
              </div>
              <span class="text-xs text-gray-500 dark:text-gray-400">5 min</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Two Sum</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm mb-4">
              Given an array of integers and a target sum, return indices of two numbers that add up to the target.
            </p>
            <div class="flex items-center justify-between">
              <div class="flex space-x-2">
                <span class="px-2 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300 text-xs rounded">Arrays</span>
                <span class="px-2 py-1 bg-purple-100 dark:bg-purple-900/30 text-purple-800 dark:text-purple-300 text-xs rounded">Hash Maps</span>
              </div>
              <button class="text-blue-600 dark:text-blue-400 font-semibold text-sm hover:text-blue-700 dark:hover:text-blue-300">
                Solve →
              </button>
            </div>
          </div>

          <!-- Medium Challenge -->
          <div class="challenge-card bg-white dark:bg-dark-800 rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow cursor-pointer" data-difficulty="medium">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center space-x-2">
                <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
                <span class="text-sm font-medium text-yellow-600 dark:text-yellow-400">Medium</span>
              </div>
              <span class="text-xs text-gray-500 dark:text-gray-400">15 min</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Binary Tree Traversal</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm mb-4">
              Implement inorder, preorder, and postorder traversal of a binary tree using recursion.
            </p>
            <div class="flex items-center justify-between">
              <div class="flex space-x-2">
                <span class="px-2 py-1 bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300 text-xs rounded">Trees</span>
                <span class="px-2 py-1 bg-orange-100 dark:bg-orange-900/30 text-orange-800 dark:text-orange-300 text-xs rounded">Recursion</span>
              </div>
              <button class="text-blue-600 dark:text-blue-400 font-semibold text-sm hover:text-blue-700 dark:hover:text-blue-300">
                Solve →
              </button>
            </div>
          </div>

          <!-- Hard Challenge -->
          <div class="challenge-card bg-white dark:bg-dark-800 rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow cursor-pointer" data-difficulty="hard">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center space-x-2">
                <div class="w-3 h-3 bg-red-500 rounded-full"></div>
                <span class="text-sm font-medium text-red-600 dark:text-red-400">Hard</span>
              </div>
              <span class="text-xs text-gray-500 dark:text-gray-400">30 min</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">LRU Cache</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm mb-4">
              Design and implement a data structure for Least Recently Used (LRU) cache with O(1) operations.
            </p>
            <div class="flex items-center justify-between">
              <div class="flex space-x-2">
                <span class="px-2 py-1 bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300 text-xs rounded">Design</span>
                <span class="px-2 py-1 bg-indigo-100 dark:bg-indigo-900/30 text-indigo-800 dark:text-indigo-300 text-xs rounded">Hash Maps</span>
              </div>
              <button class="text-blue-600 dark:text-blue-400 font-semibold text-sm hover:text-blue-700 dark:hover:text-blue-300">
                Solve →
              </button>
            </div>
          </div>

          <!-- More challenges -->
          <div class="challenge-card bg-white dark:bg-dark-800 rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow cursor-pointer" data-difficulty="easy">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center space-x-2">
                <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                <span class="text-sm font-medium text-green-600 dark:text-green-400">Easy</span>
              </div>
              <span class="text-xs text-gray-500 dark:text-gray-400">8 min</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Palindrome Check</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm mb-4">
              Write a function to check if a given string is a palindrome, ignoring spaces and case.
            </p>
            <div class="flex items-center justify-between">
              <div class="flex space-x-2">
                <span class="px-2 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300 text-xs rounded">Strings</span>
                <span class="px-2 py-1 bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300 text-xs rounded">Two Pointers</span>
              </div>
              <button class="text-blue-600 dark:text-blue-400 font-semibold text-sm hover:text-blue-700 dark:hover:text-blue-300">
                Solve →
              </button>
            </div>
          </div>

          <div class="challenge-card bg-white dark:bg-dark-800 rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow cursor-pointer" data-difficulty="medium">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center space-x-2">
                <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
                <span class="text-sm font-medium text-yellow-600 dark:text-yellow-400">Medium</span>
              </div>
              <span class="text-xs text-gray-500 dark:text-gray-400">20 min</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Merge Intervals</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm mb-4">
              Given a collection of intervals, merge all overlapping intervals and return the result.
            </p>
            <div class="flex items-center justify-between">
              <div class="flex space-x-2">
                <span class="px-2 py-1 bg-purple-100 dark:bg-purple-900/30 text-purple-800 dark:text-purple-300 text-xs rounded">Sorting</span>
                <span class="px-2 py-1 bg-orange-100 dark:bg-orange-900/30 text-orange-800 dark:text-orange-300 text-xs rounded">Intervals</span>
              </div>
              <button class="text-blue-600 dark:text-blue-400 font-semibold text-sm hover:text-blue-700 dark:hover:text-blue-300">
                Solve →
              </button>
            </div>
          </div>

          <div class="challenge-card bg-white dark:bg-dark-800 rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow cursor-pointer" data-difficulty="hard">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center space-x-2">
                <div class="w-3 h-3 bg-red-500 rounded-full"></div>
                <span class="text-sm font-medium text-red-600 dark:text-red-400">Hard</span>
              </div>
              <span class="text-xs text-gray-500 dark:text-gray-400">45 min</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Word Ladder</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm mb-4">
              Find the shortest transformation sequence from a start word to an end word using a dictionary.
            </p>
            <div class="flex items-center justify-between">
              <div class="flex space-x-2">
                <span class="px-2 py-1 bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300 text-xs rounded">BFS</span>
                <span class="px-2 py-1 bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-300 text-xs rounded">Graph</span>
              </div>
              <button class="text-blue-600 dark:text-blue-400 font-semibold text-sm hover:text-blue-700 dark:hover:text-blue-300">
                Solve →
              </button>
            </div>
          </div>
        </div>

        <div class="text-center mt-12">
          <button class="bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-3 rounded-lg font-semibold transition-colors">
            View All Challenges
          </button>
        </div>
      </div>
    </section>

    <!-- Progress Tracking -->
    <section class="py-20 bg-white dark:bg-dark-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-4">
            Track Your Progress
          </h2>
          <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
            Monitor your learning journey with detailed analytics and achievement badges.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-gradient-to-br from-blue-50 to-indigo-100 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-6 text-center">
            <div class="w-16 h-16 bg-blue-500 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
