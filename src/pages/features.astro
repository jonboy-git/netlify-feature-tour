---
import Layout from '../components/Layout.astro';
---

<Layout title="Features - AI Coding Platform">
  <!-- Hero Section -->
  <section class="relative overflow-hidden gradient-bg py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        Powerful <span class="gradient-text">AI Features</span> for Modern Developers
      </h1>
      <p class="text-xl text-muted-foreground max-w-3xl mx-auto mb-8">
        Discover how our AI-powered tools revolutionize the way you write, debug, and deploy code. 
        Everything you need to build amazing software, faster than ever.
      </p>
    </div>
  </section>

  <!-- Feature Grid -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- AI Code Generation -->
      <div class="mb-32">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="inline-flex items-center px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm font-medium mb-4">
              🤖 AI-Powered
            </div>
            <h2 class="text-3xl md:text-4xl font-bold mb-6">
              Intelligent Code Generation
            </h2>
            <p class="text-xl text-muted-foreground mb-8">
              Transform natural language descriptions into production-ready code. Our AI understands context, 
              follows best practices, and generates code that's clean, efficient, and maintainable.
            </p>
            <div class="space-y-4 mb-8">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>Generate complete functions from descriptions</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>Support for 50+ programming languages</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>Context-aware suggestions</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>Automatic documentation generation</span>
              </div>
            </div>
            <a href="/editor" class="inline-flex items-center px-6 py-3 bg-primary text-primary-foreground rounded-lg hover:bg-primary/90 transition-colors">
              Try Code Generation
              <svg class="w-4 h-4 ml-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
              </svg>
            </a>
          </div>
          <div class="relative">
            <div class="bg-card rounded-xl border shadow-lg overflow-hidden">
              <div class="bg-muted/50 px-4 py-3 flex items-center justify-between">
                <div class="flex items-center space-x-2">
                  <div class="w-3 h-3 bg-red-500 rounded-full"></div>
                  <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
                  <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                </div>
                <span class="text-sm text-muted-foreground">AI Code Generator</span>
              </div>
              <div class="p-6">
                <div class="mb-4">
                  <label class="block text-sm font-medium mb-2">Describe what you want to build:</label>
                  <div class="p-3 bg-muted rounded-lg font-mono text-sm">
                    "Create a function that validates email addresses and returns true if valid"
                  </div>
                </div>
                <div class="mb-4">
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-sm font-medium">Generated Code:</span>
                    <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded">JavaScript</span>
                  </div>
                  <div class="code-block">
                    <code class="text-sm">
function validateEmail(email) {<br>
&nbsp;&nbsp;const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;<br>
&nbsp;&nbsp;return emailRegex.test(email);<br>
}<br><br>
// Usage example:<br>
console.log(validateEmail("user@example.com")); // true<br>
console.log(validateEmail("invalid-email")); // false
                    </code>
                  </div>
                </div>
                <div class="flex items-center space-x-2">
                  <button class="px-4 py-2 bg-green-600 text-white rounded-md text-sm hover:bg-green-700 transition-colors">
                    Accept Code
                  </button>
                  <button class="px-4 py-2 border rounded-md text-sm hover:bg-muted transition-colors">
                    Refine
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Real-time Collaboration -->
      <div class="mb-32">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="lg:order-2">
            <div class="inline-flex items-center px-3 py-1 bg-purple-100 text-purple-700 rounded-full text-sm font-medium mb-4">
              🤝 Collaboration
            </div>
            <h2 class="text-3xl md:text-4xl font-bold mb-6">
              Real-time Collaboration
            </h2>
            <p class="text-xl text-muted-foreground mb-8">
              Code together with your team in real-time. See changes instantly, share ideas through voice chat, 
              and review code collaboratively. Perfect for pair programming and team projects.
            </p>
            <div class="space-y-4 mb-8">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>Live cursor tracking and selections</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>Integrated voice and video chat</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>Real-time conflict resolution</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>Shared workspace management</span>
              </div>
            </div>
            <a href="/collaboration" class="inline-flex items-center px-6 py-3 bg-primary text-primary-foreground rounded-lg hover:bg-primary/90 transition-colors">
              Start Collaborating
              <svg class="w-4 h-4 ml-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
              </svg>
            </a>
          </div>
          <div class="lg:order-1 relative">
            <div class="bg-card rounded-xl border shadow-lg overflow-hidden">
              <div class="bg-muted/50 px-4 py-3 flex items-center justify-between">
                <div class="flex items-center space-x-2">
                  <span class="text-sm font-medium">Live Session</span>
                  <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                </div>
                <div class="flex items-center space-x-2">
                  <div class="flex -space-x-2">
                    <div class="w-6 h-6 bg-blue-500 rounded-full border-2 border-white flex items-center justify-center text-xs text-white">A</div>
                    <div class="w-6 h-6 bg-green-500 rounded-full border-2 border-white flex items-center justify-center text-xs text-white">B</div>
                    <div class="w-6 h-6 bg-purple-500 rounded-full border-2 border-white flex items-center justify-center text-xs text-white">C</div>
                  </div>
                  <span class="text-xs text-muted-foreground">3 online</span>
                </div>
              </div>
              <div class="p-4">
                <div class="code-block mb-4">
                  <code class="text-sm">
function processData(data) {<br>
&nbsp;&nbsp;<span class="bg-blue-100 dark:bg-blue-900/30">// Alice is typing...</span><br>
&nbsp;&nbsp;const filtered = data.filter(<span class="bg-green-100 dark:bg-green-900/30">item => item.active</span>);<br>
&nbsp;&nbsp;return filtered.map(item => ({<br>
&nbsp;&nbsp;&nbsp;&nbsp;id: item.id,<br>
&nbsp;&nbsp;&nbsp;&nbsp;name: item.name<span class="bg-purple-100 dark:bg-purple-900/30 animate-pulse">|</span><br>
&nbsp;&nbsp;}));<br>
}
                  </code>
                </div>
                <div class="space-y-2">
                  <div class="flex items-center space-x-2 text-sm">
                    <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
                    <span class="font-medium">Alice</span>
                    <span class="text-muted-foreground">added error handling</span>
                    <span class="text-xs text-muted-foreground">2m ago</span>
                  </div>
                  <div class="flex items-center space-x-2 text-sm">
                    <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                    <span class="font-medium">Bob</span>
                    <span class="text-muted-foreground">optimized the filter logic</span>
                    <span class="text-xs text-muted-foreground">5m ago</span>
                  </div>
                  <div class="flex items-center space-x-2 text-sm">
                    <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
                    <span class="font-medium">Charlie</span>
                    <span class="text-muted-foreground">is currently editing</span>
                    <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- AI Debugging -->
      <div class="mb-32">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="inline-flex items-center px-3 py-1 bg-red-100 text-red-700 rounded-full text-sm font-medium mb-4">
              🐛 Smart Debugging
            </div>
            <h2 class="text-3xl md:text-4xl font-bold mb-6">
              AI-Powered Bug Detection
            </h2>
            <p class="text-xl text-muted-foreground mb-8">
              Find and fix bugs before they reach production. Our AI analyzes your code in real-time, 
              identifies potential issues, and suggests optimizations to improve performance and maintainability.
            </p>
            <div class="space-y-4 mb-8">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>Real-time error detection</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>Performance optimization suggestions</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>Security vulnerability scanning</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>Automatic fix suggestions</span>
              </div>
            </div>
            <a href="/debugging" class="inline-flex items-center px-6 py-3 bg-primary text-primary-foreground rounded-lg hover:bg-primary/90 transition-colors">
              Try AI Debugging
              <svg class="w-4 h-4 ml-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
              </svg>
            </a>
          </div>
          <div class="relative">
            <div class="bg-card rounded-xl border shadow-lg overflow-hidden">
              <div class="bg-muted/50 px-4 py-3 flex items-center justify-between">
                <span class="text-sm font-medium">AI Debugger</span>
                <div class="flex items-center space-x-2">
                  <div class="w-2 h-2 bg-orange-500 rounded-full"></div>
                  <span class="text-xs text-muted-foreground">3 issues found</span>
                </div>
              </div>
              <div class="p-4">
                <div class="space-y-3">
                  <div class="border border-red-200 rounded-lg p-3 bg-red-50 dark:bg-red-900/20">
                    <div class="flex items-center justify-between mb-2">
                      <span class="text-sm font-medium text-red-700 dark:text-red-400">Memory Leak Detected</span>
                      <span class="text-xs bg-red-100 text-red-700 px-2 py-1 rounded">High Priority</span>
                    </div>
                    <p class="text-sm text-red-600 dark:text-red-300 mb-2">
                      Event listener not removed in cleanup function (line 23)
                    </p>
                    <button class="text-xs bg-red-600 text-white px-2 py-1 rounded hover:bg-red-700 transition-colors">
                      Apply Fix
                    </button>
                  </div>
                  
                  <div class="border border-yellow-200 rounded-lg p-3 bg-yellow-50 dark:bg-yellow-900/20">
                    <div class="flex items-center justify-between mb-2">
                      <span class="text-sm font-medium text-yellow-700 dark:text-yellow-400">Performance Warning</span>
                      <span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-1 rounded">Medium</span>
                    </div>
                    <p class="text-sm text-yellow-600 dark:text-yellow-300 mb-2">
                      Consider using useMemo for expensive calculation (line 15)
                    </p>
                    <button class="text-xs bg-yellow-600 text-white px-2 py-1 rounded hover:bg-yellow-700 transition-colors">
                      Optimize
                    </button>
                  </div>
                  
                  <div class="border border-blue-200 rounded-lg p-3 bg-blue-50 dark:bg-blue-900/20">
                    <div class="flex items-center justify-between mb-2">
                      <span class="text-sm font-medium text-blue-700 dark:text-blue-400">Code Style</span>
                      <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded">Low</span>
                    </div>
                    <p class="text-sm text-blue-600 dark:text-blue-300 mb-2">
                      Consider destructuring props for better readability (line 8)
                    </p>
                    <button class="text-xs bg-blue-600 text-white px-2 py-1 rounded hover:bg-blue-700 transition-colors">
                      Refactor
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Multi-Language Support -->
      <div class="mb-32">
        <div class="text-center mb-16">
          <div class="inline-flex items-center px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm font-medium mb-4">
            🌐 Multi-Language
          </div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">
            Support for 50+ Programming Languages
          </h2>
          <p class="text-xl text-muted-foreground max-w-3xl mx-auto">
            Whether you're building web apps, mobile applications, or enterprise software, 
            our platform supports all major programming languages with intelligent features.
          </p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-6">
          <div class="feature-card text-center p-6">
            <div class="w-12 h-12 mx-auto mb-4 bg-yellow-100 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-yellow-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M0 0h24v24H0V0zm22.034 18.276c-.175-1.095-.888-2.015-3.003-2.873-.736-.345-1.554-.585-1.797-1.14-.091-.33-.105-.51-.046-.705.15-.646.915-.84 1.515-.66.39.12.75.42.976.9 1.034-.676 1.034-.676 1.755-1.125-.27-.42-.404-.601-.586-.78-.63-.705-1.469-1.065-2.834-1.034l-.705.089c-.676.165-1.32.525-1.71 1.005-1.14 1.291-.811 3.541.569 4.471 1.365 1.02 3.361 1.244 3.616 2.205.24 1.17-.87 1.545-1.966 1.41-.811-.18-1.26-.586-1.755-1.336l-1.83 1.051c.21.48.45.689.81 1.109 1.74 1.756 6.09 1.666 6.871-1.004.029-.09.24-.705.074-1.65l.046.067zm-8.983-7.245h-2.248c0 1.938-.009 3.864-.009 5.805 0 1.232.063 2.363-.138 2.711-.33.689-1.18.601-1.566.48-.396-.196-.597-.466-.83-.855-.063-.105-.11-.196-.127-.196l-1.825 1.125c.305.63.75 1.172 1.324 1.517.855.51 2.004.675 3.207.405.783-.226 1.458-.691 1.811-1.411.51-.93.402-2.07.397-3.346.012-2.054 0-4.109 0-6.179l.004-.056z"/>
              </svg>
            </div>
            <h3 class="font-semibold">JavaScript</h3>
          </div>
          
          <div class="feature-card text-center p-6">
            <div class="w-12 h-12 mx-auto mb-4 bg-blue-100 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M1.125 0C.502 0 0 .502 0 1.125v21.75C0 23.498.502 24 1.125 24h21.75c.623 0 1.125-.502 1.125-1.125V1.125C24 .502 23.498 0 22.875 0zm17.363 9.75c.612 0 1.154.037 1.627.111a6.38 6.38 0 0 1 1.306.34v2.458a3.95 3.95 0 0 0-.643-.361 5.093 5.093 0 0 0-.717-.26 5.453 5.453 0 0 0-1.426-.2c-.3 0-.573.028-.819.086a2.1 2.1 0 0 0-.623.242c-.17.104-.3.229-.393.374a.888.888 0 0 0-.14.49c0 .196.053.373.156.529.104.156.252.304.443.444s.423.276.696.41c.273.135.582.274.926.416.47.197.892.407 1.266.628.374.222.695.473.963.753.268.279.472.598.614.957.142.359.214.776.214 1.253 0 .657-.125 1.21-.373 1.656a3.033 3.033 0 0 1-1.012 1.085 4.38 4.38 0 0 1-1.487.596c-.566.12-1.163.18-1.79.18a9.916 9.916 0 0 1-1.84-.164 5.544 5.544 0 0 1-1.512-.493v-2.63a5.033 5.033 0 0 0 3.237 1.2c.333 0 .624-.03.872-.09.249-.06.456-.144.623-.25.166-.108.29-.234.373-.38a1.023 1.023 0 0 0-.074-1.089 2.12 2.12 0 0 0-.537-.5 5.597 5.597 0 0 0-.807-.444 27.72 27.72 0 0 0-1.007-.436c-.918-.383-1.602-.852-2.053-1.405-.45-.553-.676-1.222-.676-2.005 0-.614.123-1.141.369-1.582.246-.441.58-.804 1.004-1.089a4.494 4.494 0 0 1 1.47-.629 7.536 7.536 0 0 1 1.77-.201zm-15.113.188h9.563v2.166H9.506v9.646H6.789v-9.646H3.375z"/>
              </svg>
            </div>
            <h3 class="font-semibold">TypeScript</h3>
          </div>
          
          <div class="feature-card text-center p-6">
            <div class="w-12 h-12 mx-auto mb-4 bg-blue-100 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.25.18l.9.2.73.26.59.3.45.32.34.34.25.34.16.33.1.3.04.26.02.25v1.74H18.1l-.55-.83-.27-.84-.02-.53.27-.84.56-.83h.66m2.23 2.92l.9.2.73.26.59.3.45.32.34.34.25.34.16.33.1.3.04.26.02.25v1.74H21.1l-.55-.83-.27-.84-.02-.53.27-.84.56-.83h.66m-18.45 3.41l.9.2.73.26.59.3.45.32.34.34.25.34.16.33.1.3.04.26.02.25v1.74H3.6l-.55-.83-.27-.84-.02-.53.27-.84.56-.83h.66z"/>
              </svg>
            </div>
            <h3 class="font-semibold">Python</h3>
          </div>
          
