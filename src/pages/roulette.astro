---
import Layout from '../components/layout.astro';
---

<Layout title="Roulette - Pretty Little Bingo">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-8">
      <h1 class="text-5xl font-bold text-white mb-4 font-fancy">🎯 European Roulette</h1>
      <p class="text-xl text-white/80 mb-6">Place your bets and spin the wheel of fortune!</p>
      
      <div class="flex justify-center space-x-6 mb-8">
        <div class="bg-white/10 backdrop-blur-sm rounded-lg px-6 py-3 border border-white/20">
          <div class="text-2xl font-bold text-bingo-gold" id="player-balance">$1,000</div>
          <div class="text-sm text-white/80">Your Balance</div>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-lg px-6 py-3 border border-white/20">
          <div class="text-2xl font-bold text-bingo-gold" id="total-bet">$0</div>
          <div class="text-sm text-white/80">Total Bet</div>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-lg px-6 py-3 border border-white/20">
          <div class="text-2xl font-bold text-bingo-gold" id="session-winnings">$0</div>
          <div class="text-sm text-white/80">Session Winnings</div>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-8">
      <!-- Roulette Wheel -->
      <div class="order-2 lg:order-1">
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
          <h2 class="text-2xl font-bold text-white mb-6 text-center">Roulette Wheel</h2>
          
          <div class="relative mb-6">
            <div class="roulette-wheel" id="roulette-wheel">
              <!-- Numbers around the wheel -->
              <div class="absolute inset-0 text-white text-xs font-bold">
                <!-- Numbers will be positioned around the wheel -->
              </div>
              
              <!-- Ball -->
              <div id="roulette-ball" class="absolute w-4 h-4 bg-white rounded-full top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 z-10">
              </div>
              
              <!-- Center -->
              <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-16 h-16 bg-bingo-gold rounded-full flex items-center justify-center">
                <span class="text-black font-bold text-sm">SPIN</span>
              </div>
            </div>
          </div>

          <!-- Spin Controls -->
          <div class="text-center mb-6">
            <button id="spin-btn" class="bg-bingo-pink hover:bg-bingo-purple text-white font-bold text-xl px-8 py-4 rounded-xl transition-all duration-300 transform hover:scale-105 shadow-lg">
              🎯 SPIN WHEEL 🎯
            </button>
          </div>

          <!-- Last Results -->
          <div class="bg-black/30 rounded-lg p-4">
            <h3 class="text-white font-bold mb-3 text-center">Last 10 Results</h3>
            <div id="last-results" class="flex space-x-2 justify-center flex-wrap">
              <!-- Previous results will appear here -->
            </div>
          </div>
        </div>
      </div>

      <!-- Betting Table -->
      <div class="order-1 lg:order-2">
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
          <h2 class="text-2xl font-bold text-white mb-6 text-center">Betting Table</h2>
          
          <!-- Chip Selector -->
          <div class="mb-6">
            <h3 class="text-white font-bold mb-3">Select Chip Value</h3>
            <div class="flex space-x-2 justify-center flex-wrap gap-2">
              <button class="chip-btn chip-1 bg-white text-black" data-value="1">$1</button>
              <button class="chip-btn chip-5 bg-red-500 text-white" data-value="5">$5</button>
              <button class="chip-btn chip-10 bg-blue-500 text-white" data-value="10">$10</button>
              <button class="chip-btn chip-25 bg-green-500 text-white" data-value="25">$25</button>
              <button class="chip-btn chip-100 bg-black text-white" data-value="100">$100</button>
            </div>
          </div>

          <!-- Numbers Grid -->
          <div class="mb-6">
            <h3 class="text-white font-bold mb-3">Straight Up Bets (35:1)</h3>
            <div class="grid grid-cols-3 gap-1 mb-4">
              <!-- Single Zero -->
              <div class="col-span-3 text-center">
                <button class="bet-btn number-btn green" data-number="0" data-type="straight">0</button>
              </div>
              
              <!-- Numbers 1-36 -->
              <div class="grid grid-cols-12 gap-1 col-span-3" id="numbers-grid">
                <!-- Numbers will be generated by JavaScript -->
              </div>
            </div>
          </div>

          <!-- Outside Bets -->
          <div class="mb-6">
            <h3 class="text-white font-bold mb-3">Outside Bets</h3>
            <div class="grid grid-cols-2 gap-2 mb-4">
              <button class="bet-btn outside-btn" data-type="red">Red (1:1)</button>
              <button class="bet-btn outside-btn" data-type="black">Black (1:1)</button>
              <button class="bet-btn outside-btn" data-type="even">Even (1:1)</button>
              <button class="bet-btn outside-btn" data-type="odd">Odd (1:1)</button>
              <button class="bet-btn outside-btn" data-type="low">1-18 (1:1)</button>
              <button class="bet-btn outside-btn" data-type="high">19-36 (1:1)</button>
            </div>
            <div class="grid grid-cols-3 gap-2 mb-4">
              <button class="bet-btn outside-btn" data-type="dozen1">1st 12 (2:1)</button>
              <button class="bet-btn outside-btn" data-type="dozen2">2nd 12 (2:1)</button>
              <button class="bet-btn outside-btn" data-type="dozen3">3rd 12 (2:1)</button>
            </div>
            <div class="grid grid-cols-3 gap-2">
              <button class="bet-btn outside-btn" data-type="col1">Col 1 (2:1)</button>
              <button class="bet-btn outside-btn" data-type="col2">Col 2 (2:1)</button>
              <button class="bet-btn outside-btn" data-type="col3">Col 3 (2:1)</button>
            </div>
          </div>

          <!-- Bet Controls -->
          <div class="flex space-x-2 mb-4">
            <button id="clear-bets" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded transition-colors">
              Clear Bets
            </button>
            <button id="repeat-bet" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded transition-colors">
              Repeat Last
            </button>
          </div>

          <!-- Current Bets -->
          <div class="bg-black/30 rounded-lg p-4">
            <h3 class="text-white font-bold mb-3">Your Bets</h3>
            <div id="current-bets" class="space-y-2 max-h-40 overflow-y-auto">
              <p class="text-white/60 text-center">No bets placed</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Game Info -->
    <div class="mt-8 bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
      <h3 class="text-2xl font-bold text-white mb-6 text-center">How to Play European Roulette</h3>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-4xl mb-2">🎯</div>
          <h4 class="text-bingo-gold font-bold mb-2">Place Your Bets</h4>
          <p class="text-white/80 text-sm">Select a chip value and click on numbers or betting areas to place your bets</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-2">🎡</div>
          <h4 class="text-bingo-gold font-bold mb-2">Spin the Wheel</h4>
          <p class="text-white/80 text-sm">Click the spin button to start the wheel and drop the ball</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-2">💰</div>
          <h4 class="text-bingo-gold font-bold mb-2">Collect Winnings</h4>
          <p class="text-white/80 text-sm">If the ball lands on your number or bet, you win according to the payout odds</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .chip-btn {
    @apply w-12 h-12 rounded-full font-bold text-sm border-2 border-white/30 transition-all duration-200 transform hover:scale-110;
  }
  
  .chip-btn.selected {
    @apply ring-4 ring-bingo-gold scale-110;
  }
  
  .bet-btn {
    @apply px-3 py-2 rounded font-bold text-sm transition-all duration-200 border-2 border-transparent hover:border-bingo-gold;
  }
  
  .number-btn {
    @apply w-8 h-8 text-xs relative;
  }
  
  .number-btn.red {
    @apply bg-red-600 text-white;
  }
  
  .number-btn.black {
    @apply bg-gray-800 text-white;
  }
  
  .number-btn.green {
    @apply bg-green-600 text-white;
  }
  
  .outside-btn {
    @apply bg-blue-600 hover:bg-blue-700 text-white;
  }
  
  .bet-chip {
    @apply absolute top-0 right-0 w-4 h-4 rounded-full text-xs flex items-center justify-center transform translate-x-1 -translate-y-1;
  }
  
  .result-number {
    @apply w-8 h-8 rounded-full flex items-center justify-center text-white font-bold text-sm;
  }
  
  .result-number.red {
    @apply bg-red-600;
  }
  
  .result-number.black {
    @apply bg-gray-800;
  }
  
  .result-number.green {
    @apply bg-green-600;
  }
</style>

<script>
  import confetti from 'canvas-confetti';

  class RouletteGame {
    constructor() {
      this.balance = 1000;
      this.sessionWinnings = 0;
      this.selectedChip = 5;
      this.currentBets = {};
      this.lastBets = {};
      this.spinning = false;
      this.lastResults = [];
      
      this.redNumbers = [1, 3, 5, 7, 9, 12, 14, 16, 18, 19, 21, 23, 25, 27, 30, 32, 34, 36];
      this.blackNumbers = [2, 4, 6, 8, 10, 11, 13, 15, 17, 20, 22, 24, 26, 28, 29, 31, 33, 35];
      
      this.initializeGame();
    }

    initializeGame() {
      this.setupEventListeners();
      this.generateNumbersGrid();
      this.updateDisplay();
      this.selectChip(5); // Default chip selection
    }

    generateNumbersGrid() {
      const numbersGrid = document.getElementById('numbers-grid');
      numbersGrid.innerHTML = '';
      
      // Create 3 rows of 12 numbers each
      for (let row = 0; row < 3; row++) {
        for (let col = 0; col < 12; col++) {
          const number = (col * 3) + (3 - row);
          const button = document.createElement('button');
          button.className = `bet-btn number-btn ${this.getNumberColor(number)}`;
          button.dataset.number = number;
          button.dataset.type = 'straight';
          button.textContent = number;
          button.style.position = 'relative';
          numbersGrid.appendChild(button);
        }
      }
    }

    getNumberColor(number) {
      if (number === 0) return 'green';
      if (this.redNumbers.includes(number)) return 'red';
      return 'black';
    }

    selectChip(value) {
      this.selectedChip = value;
      
      // Update chip button states
      document.querySelectorAll('.chip-btn').forEach(btn => {
        btn.classList.remove('selected');
        if (parseInt(btn.dataset.value) === value) {
          btn.classList.add('selected');
        }
      });
    }

    placeBet(element, betType, number = null) {
      if (this.spinning) return;
      
      const chipValue = this.selectedChip;
      
      if (this.balance < chipValue) {
        this.showMessage('Insufficient balance!', 'error');
        return;
      }
      
      const betKey = betType + (number !== null ? `-${number}` : '');
      
      if (!this.currentBets[betKey]) {
        this.currentBets[betKey] = {
          type: betType,
          number: number,
          amount: 0,
          element: element
        };
      }
      
      this.currentBets[betKey].amount += chipValue;
      this.balance -= chipValue;
      
      this.updateBetDisplay(element, this.currentBets[betKey].amount);
      this.updateCurrentBetsList();
      this.updateDisplay();
    }

    updateBetDisplay(element, amount) {
      // Remove existing chip display
      const existingChip = element.querySelector('.bet-chip');
      if (existingChip) {
        existingChip.remove();
      }
      
      // Add new chip display
      if (amount > 0) {
        const chip = document.createElement('div');
        chip.className = 'bet-chip bg-bingo-gold text-black';
        chip.textContent = `$${amount}`;
        element.style.position = 'relative';
        element.appendChild(chip);
      }
    }

    updateCurrentBetsList() {
      const betsContainer = document.getElementById('current-bets');
      const bets = Object.values(this.currentBets);
      
      if (bets.length === 0) {
        betsContainer.innerHTML = '<p class="text-white/60 text-center">No bets placed</p>';
        return;
      }
      
      betsContainer.innerHTML = bets.map(bet => {
        const betName = this.getBetName(bet.type, bet.number);
        return `<div class="flex justify-between text-sm">
          <span class="text-white">${betName}</span>
          <span class="text-bingo-gold">$${bet.amount}</span>
        </div>`;
      }).join('');
    }

    getBetName(type, number) {
      switch (type) {
        case 'straight': return `Number ${number}`;
        case 'red': return 'Red';
        case 'black': return 'Black';
        case 'even': return 'Even';
        case 'odd': return 'Odd';
        case 'low': return '1-18';
        case 'high': return '19-36';
        case 'dozen1': return '1st Dozen';
        case 'dozen2': return '2nd Dozen';
        case 'dozen3': return '3rd Dozen';
        case 'col1': return 'Column 1';
        case 'col2': return 'Column 2';
        case 'col3': return 'Column 3';
        default: return type;
      }
    }

    clearBets() {
      if (this.spinning) return;
      
      // Refund all bets
      Object.values(this.currentBets).forEach(bet => {
        this.balance += bet.amount;
        this.updateBetDisplay(bet.element, 0);
      });
      
      this.currentBets = {};
      this.updateCurrentBetsList();
      this.updateDisplay();
    }

    repeatLastBet() {
      if (this.spinning || Object.keys(this.lastBets).length === 0) return;
      
      this.clearBets();
      
      // Calculate total needed
      const totalNeeded = Object.values(this.lastBets).reduce((sum, bet) => sum + bet.amount, 0);
      
      if (this.balance < totalNeeded) {
        this.showMessage('Insufficient balance for repeat bet!', 'error');
        return;
      }
      
      // Place last bets
      Object.entries(this.lastBets).forEach(([key, bet]) => {
        this.currentBets[key] = { ...bet };
        this.balance -= bet.amount;
        this.updateBetDisplay(bet.element, bet.amount);
      });
      
      this.updateCurrentBetsList();
      this.updateDisplay();
    }

    async spin() {
      if (this.spinning || Object.keys(this.currentBets).length === 0) {
        if (Object.keys(this.currentBets).length === 0) {
          this.showMessage('Please place a bet first!', 'warning');
        }
        return;
      }
      
      this.spinning = true;
      this.lastBets = { ...this.currentBets };
      
      const spinBtn = document.getElementById('spin-btn');
      spinBtn.disabled = true;
      spinBtn.textContent = 'SPINNING...';
      
      // Generate winning number
      const winningNumber = Math.floor(Math.random() * 37); // 0-36
      
      // Animate wheel
      await this.animateWheel(winningNumber);
      
      // Calculate winnings
      const winnings = this.calculateWinnings(winningNumber);
      
      // Update results
      this.addResult(winningNumber);
      this.balance += winnings;
      this.sessionWinnings += winnings - Object.values(this.currentBets).reduce((sum, bet) => sum + bet.amount, 0);
      
      // Show result
      this.showResult(winningNumber, winnings);
      
      // Clear bets
      this.clearBets();
      
      // Reset spin button
      this.spinning = false;
      spinBtn.disabled = false;
      spinBtn.textContent = '🎯 SPIN WHEEL 🎯';
      
      this.updateDisplay();
    }

    async animateWheel(winningNumber) {
      const wheel = document.getElementById('roulette-wheel');
      const ball = document.getElementById('roulette-ball');
      
      // Calculate final position for the ball
      const angle = (winningNumber / 37) * 360;
      const finalRotation = 360 * 5 + angle; // 5 full rotations + final position
      
      // Animate wheel
      wheel.style.transition = 'transform 3s ease-out';
      wheel.style.transform = `rotate(${finalRotation}deg)`;
      
      // Animate ball
      ball.style.transition = 'transform 3s ease-out';
      ball.style.transform = `rotate(${-finalRotation + 180}deg) translateY(-100px)`;
      
      // Wait for animation to complete
      await new Promise(resolve => setTimeout(resolve, 3000));
    }

    calculateWinnings(winningNumber) {
      let totalWinnings = 0;
      
      Object.values(this.currentBets).forEach(bet => {
        const multiplier = this.getWinMultiplier(bet.type, bet.number, winningNumber);
        if (multiplier > 0) {
          totalWinnings += bet.amount * (multiplier + 1); // +1 includes original bet
        }
      });
      
      return totalWinnings;
    }

    getWinMultiplier(betType, betNumber, winningNumber) {
      switch (betType) {
        case 'straight':
          return betNumber === winningNumber ? 35 : 0;
        case 'red':
          return winningNumber !== 0 && this.redNumbers.includes(winningNumber) ? 1 : 0;
        case 'black':
          return winningNumber !== 0 && this.blackNumbers.includes(winningNumber) ? 1 : 0;
        case 'even':
          return winningNumber !== 0 && winningNumber % 2 === 0 ? 1 : 0;
        case 'odd':
          return winningNumber !== 0 && winningNumber % 2 === 1 ? 1 : 0;
        case 'low':
          return winningNumber >= 1 && winningNumber <= 18 ? 1 : 0;
        case 'high':
          return winningNumber >= 19 && winningNumber <= 36 ? 1 : 0;
        case 'dozen1':
          return winningNumber >= 1 && winningNumber <= 12 ? 2 : 0;
        case 'dozen2':
          return winningNumber >= 13 && winningNumber <= 24 ? 2 : 0;
        case 'dozen3':
          return winningNumber >= 25 && winningNumber <= 36 ? 2 : 0;
        case 'col1':
          return winningNumber > 0 && winningNumber % 3 === 1 ? 2 : 0;
        case 'col2':
          return winningNumber > 0 && winningNumber % 3 === 2 ? 2 : 0;
        case 'col3':
          return winningNumber > 0 && winningNumber % 3 === 0 ? 2 : 0;
        default:
          return 0;
      }
    }

    addResult(number) {
      this.lastResults.unshift(number);
      if (this.lastResults.length > 10) {
        this.lastResults.pop();
      }
      
      const resultsContainer = document.getElementById('last-results');
      resultsContainer.innerHTML = this.lastResults.map(num => {
        const color = this.getNumberColor(num);
        return `<div class="result-number ${color}">${num}</div>`;
      }).join('');
    }

    showResult(winningNumber, winnings) {
      const color = this.getNumberColor(winningNumber);
      const colorName = color === 'green' ? 'Green' : 
                       color === 'red' ? 'Red' : 'Black';
      
      if (winnings > 0) {
        confetti({
          particleCount: 100,
          spread: 70,
          origin: { y: 0.6 }
        });
        
        this.showMessage(`🎉 Winner! ${winningNumber} ${colorName} - You won $${winnings}!`, 'success');
      } else {
        this.showMessage(`${winningNumber} ${colorName} - Better luck next time!`, 'info');
      }
    }

    updateDisplay() {
      document.getElementById('player-balance').textContent = `$${this.balance.toLocaleString()}`;
      document.getElementById('session-winnings').textContent = `$${this.sessionWinnings.toLocaleString()}`;
      
      const totalBet = Object.values(this.currentBets).reduce((sum, bet) => sum + bet.amount, 0);
      document.getElementById('total-bet').textContent = `$${totalBet}`;
    }

    showMessage(message, type) {
      const messageDiv = document.createElement('div');
      messageDiv.className = `fixed top-20 left-1/2 transform -translate-x-1/2 px-6 py-3 rounded-lg text-white font-bold z-50 ${
        type === 'success' ? 'bg-green-600' : 
        type === 'error' ? 'bg-red-600' :
        type === 'warning' ? 'bg-yellow-600' : 
        'bg-blue-600'
      }`;
      messageDiv.textContent = message;
      document.body.appendChild(messageDiv);
      
      setTimeout(() => {
        messageDiv.remove();
      }, 4000);
    }

    setupEventListeners() {
      // Chip selection
      document.querySelectorAll('.chip-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          this.selectChip(parseInt(btn.dataset.value));
        });
      });
      
      // Betting buttons
      document.addEventListener('click', (e) => {
        if (e.target.matches('.bet-btn')) {
          e.preventDefault();
          const betType = e.target.dataset.type;
          const number = e.target.dataset.number ? parseInt(e.target.dataset.number) : null;
          this.placeBet(e.target, betType, number);
        }
      });
      
      // Control buttons
      document.getElementById('spin-btn').addEventListener('click', () => {
        this.spin();
      });
      
      document.getElementById('clear-bets').addEventListener('click', () => {
        this.clearBets();
      });
      
      document.getElementById('repeat-bet').addEventListener('click', () => {
        this.repeatLastBet();
      });
    }
  }

  // Initialize roulette game when page loads
  document.addEventListener('DOMContentLoaded', () => {
    const roulette = new RouletteGame();
  });
</script>