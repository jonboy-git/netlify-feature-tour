---
import Layout from '../components/layout.astro';
---

<Layout title="Classic Bingo - Pretty Little Bingo">
  <div class="max-w-6xl mx-auto">
    <!-- Game Header -->
    <div class="text-center mb-8">
      <h1 class="text-5xl font-bold text-white mb-4 font-fancy">🎱 Classic Bingo</h1>
      <p class="text-xl text-white/80 mb-6">75-Ball American Bingo - Get ready to shout "BINGO!"</p>
      
      <div class="flex justify-center space-x-6 mb-8">
        <div class="bg-white/10 backdrop-blur-sm rounded-lg px-6 py-3 border border-white/20">
          <div class="text-2xl font-bold text-bingo-gold" id="prize-pool">$5,890</div>
          <div class="text-sm text-white/80">Prize Pool</div>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-lg px-6 py-3 border border-white/20">
          <div class="text-2xl font-bold text-bingo-gold" id="players-count">1,247</div>
          <div class="text-sm text-white/80">Players</div>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-lg px-6 py-3 border border-white/20">
          <div class="text-2xl font-bold text-bingo-gold" id="game-timer">02:34</div>
          <div class="text-sm text-white/80">Next Game</div>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Bingo Card -->
      <div class="lg:col-span-2">
        <div class="bingo-card mx-auto max-w-md">
          <div class="text-center mb-4">
            <h2 class="text-2xl font-bold text-gray-800">Your Bingo Card</h2>
            <p class="text-sm text-gray-600">Card #BG-4729</p>
          </div>
          
          <!-- Bingo Header -->
          <div class="grid grid-cols-5 gap-1 mb-2">
            <div class="bingo-cell bg-blue-600 text-white font-bold">B</div>
            <div class="bingo-cell bg-red-600 text-white font-bold">I</div>
            <div class="bingo-cell bg-gray-800 text-white font-bold">N</div>
            <div class="bingo-cell bg-green-600 text-white font-bold">G</div>
            <div class="bingo-cell bg-yellow-500 text-white font-bold">O</div>
          </div>
          
          <!-- Bingo Grid -->
          <div class="grid grid-cols-5 gap-1" id="bingo-grid">
            <!-- Grid will be populated by JavaScript -->
          </div>
          
          <div class="mt-4 text-center">
            <button id="new-card-btn" class="bg-bingo-purple hover:bg-bingo-pink text-white px-6 py-2 rounded-lg transition-colors">
              New Card ($5)
            </button>
          </div>
        </div>
      </div>

      <!-- Game Panel -->
      <div class="space-y-6">
        <!-- Current Ball -->
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
          <h3 class="text-xl font-bold text-white mb-4 text-center">Current Ball</h3>
          <div class="text-center">
            <div id="current-ball" class="bingo-ball bingo-ball-b mx-auto mb-4">B-7</div>
            <button id="call-ball-btn" class="bg-bingo-gold hover:bg-yellow-600 text-black px-6 py-2 rounded-lg font-bold transition-colors">
              Call Next Ball
            </button>
          </div>
        </div>

        <!-- Called Numbers -->
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
          <h3 class="text-xl font-bold text-white mb-4">Called Numbers</h3>
          <div id="called-numbers" class="grid grid-cols-5 gap-2 max-h-48 overflow-y-auto">
            <!-- Called numbers will appear here -->
          </div>
        </div>

        <!-- Chat -->
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
          <h3 class="text-xl font-bold text-white mb-4">Game Chat</h3>
          <div id="chat-messages" class="space-y-2 max-h-40 overflow-y-auto mb-4">
            <div class="text-sm text-white/80">
              <span class="text-bingo-gold font-bold">Player247:</span> Good luck everyone! 🍀
            </div>
            <div class="text-sm text-white/80">
              <span class="text-bingo-gold font-bold">BingoQueen:</span> One more number needed! 
            </div>
            <div class="text-sm text-white/80">
              <span class="text-bingo-gold font-bold">LuckyLady:</span> Come on B-12! 
            </div>
          </div>
          <div class="flex space-x-2">
            <input type="text" id="chat-input" placeholder="Type a message..." 
                   class="flex-1 px-3 py-2 rounded bg-white/20 text-white placeholder-white/60 border border-white/30 focus:outline-none focus:border-bingo-gold">
            <button id="send-chat" class="bg-bingo-pink hover:bg-bingo-purple px-4 py-2 rounded text-white transition-colors">
              Send
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Pattern Guide -->
    <div class="mt-12 bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
      <h3 class="text-2xl font-bold text-white mb-6 text-center">Winning Patterns</h3>
      <div class="grid md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="text-3xl mb-2">━</div>
          <h4 class="text-bingo-gold font-bold">Horizontal Line</h4>
          <p class="text-sm text-white/80">Complete any horizontal row</p>
        </div>
        <div class="text-center">
          <div class="text-3xl mb-2">┃</div>
          <h4 class="text-bingo-gold font-bold">Vertical Line</h4>
          <p class="text-sm text-white/80">Complete any vertical column</p>
        </div>
        <div class="text-center">
          <div class="text-3xl mb-2">╲</div>
          <h4 class="text-bingo-gold font-bold">Diagonal</h4>
          <p class="text-sm text-white/80">Complete either diagonal</p>
        </div>
        <div class="text-center">
          <div class="text-3xl mb-2">⬜</div>
          <h4 class="text-bingo-gold font-bold">Full House</h4>
          <p class="text-sm text-white/80">Mark all numbers on your card</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import confetti from 'canvas-confetti';

  class BingoGame {
    constructor() {
      this.bingoCard = this.generateBingoCard();
      this.calledNumbers = [];
      this.markedCells = new Set();
      this.gameActive = false;
      this.initializeGame();
    }

    generateBingoCard() {
      const card = [];
      
      // B column: 1-15
      const bColumn = this.getRandomNumbers(1, 15, 5);
      // I column: 16-30
      const iColumn = this.getRandomNumbers(16, 30, 5);
      // N column: 31-45 (with FREE space in middle)
      const nColumn = this.getRandomNumbers(31, 45, 4);
      nColumn.splice(2, 0, 'FREE');
      // G column: 46-60
      const gColumn = this.getRandomNumbers(46, 60, 5);
      // O column: 61-75
      const oColumn = this.getRandomNumbers(61, 75, 5);
      
      for (let row = 0; row < 5; row++) {
        card.push([
          bColumn[row],
          iColumn[row],
          nColumn[row],
          gColumn[row],
          oColumn[row]
        ]);
      }
      
      return card;
    }

    getRandomNumbers(min, max, count) {
      const numbers = [];
      const available = Array.from({length: max - min + 1}, (_, i) => min + i);
      
      for (let i = 0; i < count; i++) {
        const randomIndex = Math.floor(Math.random() * available.length);
        numbers.push(available.splice(randomIndex, 1)[0]);
      }
      
      return numbers;
    }

    initializeGame() {
      this.renderBingoCard();
      this.setupEventListeners();
      this.markedCells.add('2-2'); // Mark FREE space
      this.updateCardDisplay();
    }

    renderBingoCard() {
      const grid = document.getElementById('bingo-grid');
      grid.innerHTML = '';
      
      for (let row = 0; row < 5; row++) {
        for (let col = 0; col < 5; col++) {
          const cell = document.createElement('div');
          const value = this.bingoCard[row][col];
          cell.className = 'bingo-cell';
          cell.textContent = value;
          cell.dataset.row = row;
          cell.dataset.col = col;
          cell.dataset.value = value;
          
          if (value === 'FREE') {
            cell.classList.add('marked');
          }
          
          cell.addEventListener('click', () => this.toggleCell(row, col));
          grid.appendChild(cell);
        }
      }
    }

    toggleCell(row, col) {
      const cellKey = `${row}-${col}`;
      const value = this.bingoCard[row][col];
      
      if (value === 'FREE') return;
      
      // Only allow marking if number has been called
      if (!this.calledNumbers.includes(value)) {
        this.showMessage('This number hasn\'t been called yet!', 'warning');
        return;
      }
      
      if (this.markedCells.has(cellKey)) {
        this.markedCells.delete(cellKey);
      } else {
        this.markedCells.add(cellKey);
      }
      
      this.updateCardDisplay();
      this.checkForWin();
    }

    updateCardDisplay() {
      const cells = document.querySelectorAll('#bingo-grid .bingo-cell');
      cells.forEach(cell => {
        const row = cell.dataset.row;
        const col = cell.dataset.col;
        const cellKey = `${row}-${col}`;
        
        if (this.markedCells.has(cellKey)) {
          cell.classList.add('marked');
        } else {
          cell.classList.remove('marked');
        }
      });
    }

    callNumber() {
      // Generate available numbers
      const allNumbers = [];
      for (let i = 1; i <= 75; i++) {
        if (!this.calledNumbers.includes(i)) {
          allNumbers.push(i);
        }
      }
      
      if (allNumbers.length === 0) {
        this.showMessage('All numbers have been called!', 'info');
        return;
      }
      
      const randomNumber = allNumbers[Math.floor(Math.random() * allNumbers.length)];
      this.calledNumbers.push(randomNumber);
      
      // Determine letter
      let letter;
      if (randomNumber <= 15) letter = 'B';
      else if (randomNumber <= 30) letter = 'I';
      else if (randomNumber <= 45) letter = 'N';
      else if (randomNumber <= 60) letter = 'G';
      else letter = 'O';
      
      // Update current ball display
      const currentBall = document.getElementById('current-ball');
      currentBall.textContent = `${letter}-${randomNumber}`;
      currentBall.className = `bingo-ball bingo-ball-${letter.toLowerCase()}`;
      
      // Add to called numbers display
      this.addCalledNumber(letter, randomNumber);
      
      // Add chat message
      this.addChatMessage('Caller', `${letter}-${randomNumber} has been called!`);
      
      // Check if player has this number
      this.checkPlayerCard(randomNumber);
    }

    addCalledNumber(letter, number) {
      const calledNumbersGrid = document.getElementById('called-numbers');
      const ball = document.createElement('div');
      ball.className = `bingo-ball bingo-ball-${letter.toLowerCase()} text-xs`;
      ball.textContent = `${letter}${number}`;
      calledNumbersGrid.appendChild(ball);
      
      // Scroll to bottom
      calledNumbersGrid.scrollTop = calledNumbersGrid.scrollHeight;
    }

    checkPlayerCard(number) {
      // Check if player has this number on their card
      for (let row = 0; row < 5; row++) {
        for (let col = 0; col < 5; col++) {
          if (this.bingoCard[row][col] === number) {
            this.showMessage(`You have ${number}! Click to mark it.`, 'success');
            // Highlight the cell temporarily
            const cell = document.querySelector(`[data-row="${row}"][data-col="${col}"]`);
            cell.style.animation = 'pulse-fast 2s';
            setTimeout(() => {
              cell.style.animation = '';
            }, 2000);
            return;
          }
        }
      }
    }

    checkForWin() {
      // Check horizontal lines
      for (let row = 0; row < 5; row++) {
        let count = 0;
        for (let col = 0; col < 5; col++) {
          if (this.markedCells.has(`${row}-${col}`)) count++;
        }
        if (count === 5) {
          this.winGame('Horizontal Line');
          return;
        }
      }
      
      // Check vertical lines
      for (let col = 0; col < 5; col++) {
        let count = 0;
        for (let row = 0; row < 5; row++) {
          if (this.markedCells.has(`${row}-${col}`)) count++;
        }
        if (count === 5) {
          this.winGame('Vertical Line');
          return;
        }
      }
      
      // Check diagonals
      let diag1Count = 0, diag2Count = 0;
      for (let i = 0; i < 5; i++) {
        if (this.markedCells.has(`${i}-${i}`)) diag1Count++;
        if (this.markedCells.has(`${i}-${4-i}`)) diag2Count++;
      }
      
      if (diag1Count === 5 || diag2Count === 5) {
        this.winGame('Diagonal');
        return;
      }
      
      // Check full house
      if (this.markedCells.size === 25) {
        this.winGame('Full House');
        return;
      }
    }

    winGame(pattern) {
      confetti({
        particleCount: 100,
        spread: 70,
        origin: { y: 0.6 }
      });
      
      this.showMessage(`BINGO! You won with a ${pattern}! 🎉`, 'success');
      this.addChatMessage('System', `🎉 Player won with ${pattern}!`);
      
      // Disable further play
      setTimeout(() => {
        if (confirm('Congratulations! You won! Start a new game?')) {
          this.newGame();
        }
      }, 2000);
    }

    newGame() {
      this.bingoCard = this.generateBingoCard();
      this.calledNumbers = [];
      this.markedCells = new Set();
      this.markedCells.add('2-2'); // Mark FREE space
      
      // Clear displays
      document.getElementById('called-numbers').innerHTML = '';
      document.getElementById('current-ball').textContent = 'Ready';
      document.getElementById('current-ball').className = 'bingo-ball bingo-ball-n mx-auto mb-4';
      
      this.renderBingoCard();
      this.addChatMessage('System', 'New game started! Good luck! 🍀');
    }

    addChatMessage(username, message) {
      const chatMessages = document.getElementById('chat-messages');
      const messageDiv = document.createElement('div');
      messageDiv.className = 'text-sm text-white/80';
      messageDiv.innerHTML = `<span class="text-bingo-gold font-bold">${username}:</span> ${message}`;
      chatMessages.appendChild(messageDiv);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    showMessage(message, type) {
      const messageDiv = document.createElement('div');
      messageDiv.className = `fixed top-20 left-1/2 transform -translate-x-1/2 px-6 py-3 rounded-lg text-white font-bold z-50 ${
        type === 'success' ? 'bg-green-600' : 
        type === 'warning' ? 'bg-yellow-600' : 
        'bg-blue-600'
      }`;
      messageDiv.textContent = message;
      document.body.appendChild(messageDiv);
      
      setTimeout(() => {
        messageDiv.remove();
      }, 3000);
    }

    setupEventListeners() {
      document.getElementById('call-ball-btn').addEventListener('click', () => {
        this.callNumber();
      });
      
      document.getElementById('new-card-btn').addEventListener('click', () => {
        if (confirm('Get a new bingo card for $5?')) {
          this.newGame();
        }
      });
      
      document.getElementById('send-chat').addEventListener('click', () => {
        this.sendChatMessage();
      });
      
      document.getElementById('chat-input').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          this.sendChatMessage();
        }
      });
    }

    sendChatMessage() {
      const input = document.getElementById('chat-input');
      const message = input.value.trim();
      if (message) {
        this.addChatMessage('You', message);
        input.value = '';
      }
    }
  }

  // Initialize game when page loads
  document.addEventListener('DOMContentLoaded', () => {
    const game = new BingoGame();
    
    // Simulate some initial called numbers for demo
    setTimeout(() => {
      game.callNumber();
    }, 1000);
  });
</script>