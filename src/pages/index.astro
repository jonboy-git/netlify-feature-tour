---
import Layout from '../components/Layout.astro';
---

<Layout title="AI Coding Site - The Ultimate AI-Powered Development Platform">
  <!-- Hero Section -->
  <section class="relative overflow-hidden gradient-bg">
    <div class="absolute inset-0 bg-grid-white/[0.02] bg-[size:60px_60px]"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-32">
      <div class="text-center">
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-primary/10 border border-primary/20 mb-8">
          <div class="w-2 h-2 bg-green-500 rounded-full mr-2 animate-pulse"></div>
          <span class="text-sm font-medium">🚀 Now with GPT-4 Integration</span>
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-6">
          <span class="gradient-text">Code with AI</span><br>
          <span class="text-foreground">Build the Future</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-muted-foreground max-w-3xl mx-auto mb-12">
          The ultimate AI-powered development platform. Write better code faster with intelligent assistance, 
          real-time collaboration, and cutting-edge tools.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
          <a href="/editor" class="inline-flex items-center px-8 py-4 rounded-lg bg-primary text-primary-foreground font-semibold hover:bg-primary/90 transition-all duration-300 shadow-lg hover:shadow-glow">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path>
            </svg>
            Start Coding Now
          </a>
          <a href="/demo" class="inline-flex items-center px-8 py-4 rounded-lg border bg-background hover:bg-muted transition-all duration-300">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"></path>
            </svg>
            Watch Demo
          </a>
        </div>
        
        <!-- Live Code Demo -->
        <div class="max-w-4xl mx-auto">
          <div class="bg-card rounded-xl border shadow-2xl overflow-hidden">
            <div class="bg-muted/50 px-4 py-3 flex items-center space-x-2">
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <span class="text-sm text-muted-foreground ml-4">main.js</span>
            </div>
            <div class="p-6 font-mono text-sm">
              <div class="space-y-2">
                <div class="text-muted-foreground">// AI-generated function</div>
                <div><span class="text-blue-600">function</span> <span class="text-yellow-600">calculateFibonacci</span><span class="text-foreground">(n) {</span></div>
                <div class="pl-4"><span class="text-purple-600">if</span> <span class="text-foreground">(n <= 1) </span><span class="text-purple-600">return</span> <span class="text-foreground">n;</span></div>
                <div class="pl-4"><span class="text-purple-600">return</span> <span class="text-yellow-600">calculateFibonacci</span><span class="text-foreground">(n - 1) + </span><span class="text-yellow-600">calculateFibonacci</span><span class="text-foreground">(n - 2);</span></div>
                <div><span class="text-foreground">}</span></div>
                <div class="mt-4">
                  <span class="text-green-600">// ✨ AI Suggestion: Optimize with memoization</span>
                  <div class="inline-block ml-2 px-2 py-1 bg-primary/10 text-primary text-xs rounded animate-pulse">
                    Apply suggestion
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          <span class="gradient-text">Supercharge</span> Your Development
        </h2>
        <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
          Everything you need to build amazing software, powered by cutting-edge AI technology.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- AI Code Generation -->
        <div class="feature-card">
          <div class="w-12 h-12 bg-gradient-to-r from-blue-500 to-cyan-500 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">AI Code Generation</h3>
          <p class="text-muted-foreground mb-4">Generate complete functions, classes, and modules with natural language prompts. Our AI understands context and follows best practices.</p>
          <a href="/features/ai-generation" class="text-primary hover:text-primary/80 font-medium inline-flex items-center">
            Learn more
            <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>

        <!-- Real-time Collaboration -->
        <div class="feature-card">
          <div class="w-12 h-12 bg-gradient-to-r from-purple-500 to-pink-500 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Real-time Collaboration</h3>
          <p class="text-muted-foreground mb-4">Code together with your team in real-time. Share workspaces, review code, and communicate seamlessly with integrated voice chat.</p>
          <a href="/features/collaboration" class="text-primary hover:text-primary/80 font-medium inline-flex items-center">
            Learn more
            <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>

        <!-- Smart Debugging -->
        <div class="feature-card">
          <div class="w-12 h-12 bg-gradient-to-r from-green-500 to-emerald-500 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Smart Debugging</h3>
          <p class="text-muted-foreground mb-4">AI-powered bug detection and fixes. Get intelligent suggestions for performance optimization and code quality improvements.</p>
          <a href="/features/debugging" class="text-primary hover:text-primary/80 font-medium inline-flex items-center">
            Learn more
            <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>

        <!-- Multi-language Support -->
        <div class="feature-card">
          <div class="w-12 h-12 bg-gradient-to-r from-orange-500 to-red-500 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Multi-language Support</h3>
          <p class="text-muted-foreground mb-4">Support for 50+ programming languages including JavaScript, Python, Go, Rust, and more. With intelligent syntax highlighting and completion.</p>
          <a href="/features/languages" class="text-primary hover:text-primary/80 font-medium inline-flex items-center">
            Learn more
            <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>

        <!-- Cloud Deployment -->
        <div class="feature-card">
          <div class="w-12 h-12 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M5.5 16a3.5 3.5 0 01-.369-6.98 4 4 0 117.753-1.977A4.5 4.5 0 1113.5 16h-8z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">One-Click Deployment</h3>
          <p class="text-muted-foreground mb-4">Deploy your projects instantly to AWS, Vercel, Netlify, and more. Automated CI/CD pipelines and environment management included.</p>
          <a href="/features/deployment" class="text-primary hover:text-primary/80 font-medium inline-flex items-center">
            Learn more
            <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>

        <!-- Learning & Tutorials -->
        <div class="feature-card">
          <div class="w-12 h-12 bg-gradient-to-r from-teal-500 to-blue-500 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Interactive Learning</h3>
          <p class="text-muted-foreground mb-4">Learn coding with AI-powered tutorials, interactive challenges, and personalized learning paths. Perfect for beginners and experts alike.</p>
          <a href="/tutorials" class="text-primary hover:text-primary/80 font-medium inline-flex items-center">
            Learn more
            <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Statistics Section -->
  <section class="py-24 bg-muted/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-4xl md:text-5xl font-bold gradient-text mb-2">500K+</div>
          <div class="text-muted-foreground">Active Developers</div>
        </div>
        <div>
          <div class="text-4xl md:text-5xl font-bold gradient-text mb-2">10M+</div>
          <div class="text-muted-foreground">Lines of Code Generated</div>
        </div>
        <div>
          <div class="text-4xl md:text-5xl font-bold gradient-text mb-2">99.9%</div>
          <div class="text-muted-foreground">Uptime</div>
        </div>
        <div>
          <div class="text-4xl md:text-5xl font-bold gradient-text mb-2">50+</div>
          <div class="text-muted-foreground">Programming Languages</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Ready to <span class="gradient-text">Code the Future</span>?
      </h2>
      <p class="text-xl text-muted-foreground mb-8">
        Join thousands of developers already building amazing projects with AI assistance.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/signup" class="inline-flex items-center px-8 py-4 rounded-lg bg-primary text-primary-foreground font-semibold hover:bg-primary/90 transition-all duration-300 shadow-lg hover:shadow-glow">
          Start Free Trial
        </a>
        <a href="/pricing" class="inline-flex items-center px-8 py-4 rounded-lg border hover:bg-muted transition-all duration-300">
          View Pricing
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Add smooth scrolling and animations
  document.addEventListener('DOMContentLoaded', function() {
    // Animate feature cards on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-slide-up');
        }
      });
    });

    document.querySelectorAll('.feature-card').forEach((card) => {
      observer.observe(card);
    });
  });
</script>
