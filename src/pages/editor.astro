---
import Layout from '../components/layout.astro';
---

<Layout
  title="AI Code Editor - Write Code with Intelligence"
  description="Professional code editor with AI assistance, syntax highlighting, and intelligent auto-completion."
>
  <div class="min-h-screen bg-gray-50 dark:bg-dark-900">
    <!-- Editor Header -->
    <div class="bg-white dark:bg-dark-800 border-b border-gray-200 dark:border-dark-700 px-6 py-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-4">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">AI Code Editor</h1>
          <div class="flex items-center space-x-2">
            <select id="languageSelect" class="bg-gray-100 dark:bg-dark-700 border border-gray-300 dark:border-dark-600 rounded-lg px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="javascript">JavaScript</option>
              <option value="typescript">TypeScript</option>
              <option value="python">Python</option>
              <option value="java">Java</option>
              <option value="cpp">C++</option>
              <option value="html">HTML</option>
              <option value="css">CSS</option>
              <option value="json">JSON</option>
              <option value="markdown">Markdown</option>
            </select>
          </div>
        </div>
        
        <div class="flex items-center space-x-3">
          <button id="aiAssistBtn" class="bg-primary-600 hover:bg-primary-700 text-white px-4 py-2 rounded-lg font-medium transition-colors">
            <span class="flex items-center space-x-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              <span>AI Assist</span>
            </span>
          </button>
          <button id="runBtn" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg font-medium transition-colors">
            <span class="flex items-center space-x-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
              <span>Run</span>
            </span>
          </button>
          <button id="saveBtn" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg font-medium transition-colors">
            <span class="flex items-center space-x-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"/>
              </svg>
              <span>Save</span>
            </span>
          </button>
        </div>
      </div>
    </div>

    <!-- Editor Layout -->
    <div class="flex h-screen pt-16">
      <!-- File Explorer Sidebar -->
      <div class="w-64 bg-white dark:bg-dark-800 border-r border-gray-200 dark:border-dark-700 overflow-y-auto">
        <div class="p-4">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wide">Files</h3>
            <button class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
              </svg>
            </button>
          </div>
          
          <div class="space-y-1">
            <div class="flex items-center space-x-2 p-2 hover:bg-gray-100 dark:hover:bg-dark-700 rounded cursor-pointer">
              <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z"/>
              </svg>
              <span class="text-sm text-gray-700 dark:text-gray-300">main.js</span>
            </div>
            <div class="flex items-center space-x-2 p-2 hover:bg-gray-100 dark:hover:bg-dark-700 rounded cursor-pointer">
              <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z"/>
              </svg>
              <span class="text-sm text-gray-700 dark:text-gray-300">styles.css</span>
            </div>
            <div class="flex items-center space-x-2 p-2 hover:bg-gray-100 dark:hover:bg-dark-700 rounded cursor-pointer">
              <svg class="w-4 h-4 text-orange-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z"/>
              </svg>
              <span class="text-sm text-gray-700 dark:text-gray-300">index.html</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Main Editor Area -->
      <div class="flex-1 flex flex-col">
        <!-- Tab Bar -->
        <div class="bg-gray-100 dark:bg-dark-700 border-b border-gray-200 dark:border-dark-600 px-4">
          <div class="flex space-x-1">
            <div class="flex items-center space-x-2 bg-white dark:bg-dark-800 px-4 py-2 border-b-2 border-primary-500">
              <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z"/>
              </svg>
              <span class="text-sm font-medium text-gray-700 dark:text-gray-300">main.js</span>
              <button class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Monaco Editor Container -->
        <div class="flex-1 relative">
          <div id="monaco-editor" class="w-full h-full"></div>
          
          <!-- AI Suggestions Panel -->
          <div id="aiPanel" class="absolute top-4 right-4 w-80 bg-white dark:bg-dark-800 border border-gray-200 dark:border-dark-700 rounded-lg shadow-lg hidden">
            <div class="p-4 border-b border-gray-200 dark:border-dark-700">
              <div class="flex items-center justify-between">
                <h4 class="font-semibold text-gray-900 dark:text-white">AI Assistant</h4>
                <button id="closePanelBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                  </svg>
                </button>
              </div>
            </div>
            <div class="p-4">
              <div class="space-y-3">
                <div class="p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
                  <div class="text-sm font-medium text-blue-900 dark:text-blue-300 mb-1">Suggestion</div>
                  <div class="text-sm text-blue-800 dark:text-blue-200">Add error handling to this function</div>
                </div>
                <div class="p-3 bg-green-50 dark:bg-green-900/20 rounded-lg">
                  <div class="text-sm font-medium text-green-900 dark:text-green-300 mb-1">Optimization</div>
                  <div class="text-sm text-green-800 dark:text-green-200">Consider using async/await here</div>
                </div>
                <div class="p-3 bg-yellow-50 dark:bg-yellow-900/20 rounded-lg">
                  <div class="text-sm font-medium text-yellow-900 dark:text-yellow-300 mb-1">Best Practice</div>
                  <div class="text-sm text-yellow-800 dark:text-yellow-200">Add JSDoc comments for better documentation</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Output Panel -->
      <div class="w-80 bg-white dark:bg-dark-800 border-l border-gray-200 dark:border-dark-700 flex flex-col">
        <div class="p-4 border-b border-gray-200 dark:border-dark-700">
          <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wide">Output</h3>
        </div>
        <div class="flex-1 p-4">
          <div id="output" class="bg-gray-900 text-green-400 p-4 rounded-lg font-mono text-sm h-full overflow-y-auto">
            <div class="text-gray-500">// Run your code to see output here</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Monaco Editor Script -->
  <script>
    import('https://cdn.jsdelivr.net/npm/monaco-editor@0.44.0/min/vs/loader.js').then(() => {
      require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.44.0/min/vs' } });
      
      require(['vs/editor/editor.main'], function () {
        const editor = monaco.editor.create(document.getElementById('monaco-editor'), {
          value: `// Welcome to AI Coder!
// This is your intelligent code editor with AI assistance.

function fibonacci(n) {
    if (n <= 1) return n;
    return fibonacci(n - 1) + fibonacci(n - 2);
}

// Try asking the AI assistant for help!
console.log('Fibonacci sequence:');
for (let i = 0; i < 10; i++) {
    console.log(\`F(\${i}) = \${fibonacci(i)}\`);
}`,
          language: 'javascript',
          theme: document.documentElement.classList.contains('dark') ? 'vs-dark' : 'vs',
          automaticLayout: true,
          fontSize: 14,
          lineNumbers: 'on',
          wordWrap: 'on',
          minimap: {
            enabled: true
          },
          suggestOnTriggerCharacters: true,
          quickSuggestions: true,
          parameterHints: {
            enabled: true
          }
        });

        // Language selection
        const languageSelect = document.getElementById('languageSelect');
        languageSelect.addEventListener('change', (e) => {
          monaco.editor.setModelLanguage(editor.getModel(), e.target.value);
        });

        // AI Assistant Panel
        const aiAssistBtn = document.getElementById('aiAssistBtn');
        const aiPanel = document.getElementById('aiPanel');
        const closePanelBtn = document.getElementById('closePanelBtn');

        aiAssistBtn.addEventListener('click', () => {
          aiPanel.classList.toggle('hidden');
        });

        closePanelBtn.addEventListener('click', () => {
          aiPanel.classList.add('hidden');
        });

        // Run code
        const runBtn = document.getElementById('runBtn');
        const output = document.getElementById('output');

        runBtn.addEventListener('click', () => {
          const code = editor.getValue();
          output.innerHTML = '';
          
          // Simple code execution simulation
          try {
            const result = eval(code);
            output.innerHTML = `<div class="text-green-400">Code executed successfully!</div>
                               <div class="text-gray-300 mt-2">Check console for output.</div>`;
          } catch (error) {
            output.innerHTML = `<div class="text-red-400">Error: ${error.message}</div>`;
          }
        });

        // Save code
        const saveBtn = document.getElementById('saveBtn');
        saveBtn.addEventListener('click', () => {
          const code = editor.getValue();
          localStorage.setItem('ai-coder-content', code);
          
          // Show save notification
          const notification = document.createElement('div');
          notification.className = 'fixed top-20 right-4 bg-green-500 text-white px-4 py-2 rounded-lg shadow-lg z-50';
          notification.textContent = 'Code saved successfully!';
          document.body.appendChild(notification);
          
          setTimeout(() => {
            notification.remove();
          }, 3000);
        });

        // Load saved code
        const savedCode = localStorage.getItem('ai-coder-content');
        if (savedCode) {
          editor.setValue(savedCode);
        }

        // Theme sync
        const observer = new MutationObserver(() => {
          const theme = document.documentElement.classList.contains('dark') ? 'vs-dark' : 'vs';
          monaco.editor.setTheme(theme);
        });

        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ['class']
        });
      });
    });
  </script>
</Layout>